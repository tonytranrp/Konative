# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# CMake build directories (CMakePresets.json's own binaryDir convention)
build/

# clangd / IDE index caches
.cache/
compile_commands.json

# Gradle (testapp/) - caches, wrapper jar, and build output; none of this is vendored
testapp/.gradle/
testapp/**/build/
testapp/.idea/
testapp/local.properties
testapp/gradle/wrapper/gradle-wrapper.jar
testapp/gradlew
testapp/gradlew.bat

# CMake's own convention: machine-local preset overrides (real NDK/SDK/kotlinc paths for
# whoever's actual dev machine this is) never get committed - see CMakeUserPresets.json itself.
CMakeUserPresets.json
