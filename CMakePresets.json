{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 23, "patch": 0 },
  "configurePresets": [
    {
      "name": "desktop-debug",
      "displayName": "Desktop Debug (host tools, no Android/Kotlin-Native)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/desktop-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "KONATIVE_BUILD_KOTLIN_NATIVE": "OFF"
      }
    },
    {
      "name": "android-arm64",
      "displayName": "Android arm64-v8a (Debug)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/android-arm64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-26"
      }
    },
    {
      "name": "android-x86_64",
      "displayName": "Android x86_64 (Debug, emulator)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/android-x86_64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "x86_64",
        "ANDROID_PLATFORM": "android-26"
      }
    }
  ]
}
